rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false; // default deny catch-all
    }

    // Primitive Definition
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "gamefromaaditya@gmail.com" && request.auth.token.email_verified == true)
      ); 
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    function isValidUserCreate(data) {
      return data.keys().hasAll(['uid', 'email', 'name', 'points', 'streak', 'role']) &&
             data.keys().size() <= 17 && // to account for all optional fields
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.points is number && data.points >= 0 &&
             data.streak is number && data.streak >= 0 &&
             data.role in ['user', 'admin'];
    }

    function isValidUserPublicCreate(data) {
      return data.keys().hasAll(['uid', 'name', 'points', 'rank']) &&
             data.keys().size() <= 6 &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.points is number && data.points >= 0 &&
             data.rank is number && data.rank >= 0;
    }

    function isValidActivityCreate(data) {
      return data.keys().hasAll(['userId', 'date', 'questionsSolved', 'accuracy', 'timeSpent', 'pointsEarned']) &&
             data.keys().size() == 6 &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 100 &&
             data.date is string && data.date.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.questionsSolved is number && data.questionsSolved >= 0 &&
             data.accuracy is number && data.accuracy >= 0 && data.accuracy <= 100 &&
             data.timeSpent is number && data.timeSpent >= 0 &&
             data.pointsEarned is number && data.pointsEarned >= 0;
    }

    function isValidCommunitySolutionCreate(data) {
      return data.keys().hasAll(['id', 'questionId', 'authorId', 'author', 'text', 'tag', 'upvotes', 'downvotes', 'repliesCount', 'date', 'createdAt']) &&
             data.keys().size() <= 14 &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.questionId is string && data.questionId.size() > 0 && data.questionId.size() < 100 &&
             data.authorId is string && data.authorId.size() > 0 && data.authorId.size() < 100 &&
             data.author is string && data.author.size() > 0 && data.author.size() < 100 &&
             data.text is string && data.text.size() > 0 && data.text.size() < 10000 &&
             data.tag is string && data.tag.size() < 50 &&
             data.upvotes is number && data.upvotes >= 0 &&
             data.downvotes is number && data.downvotes >= 0 &&
             data.repliesCount is number && data.repliesCount >= 0 &&
             data.date is string && data.date.size() < 50 &&
             data.createdAt is number;
    }

    function isValidSolutionReplyCreate(data) {
      return data.keys().hasAll(['id', 'solutionId', 'authorId', 'author', 'text', 'date', 'createdAt']) &&
             data.keys().size() <= 8 &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.solutionId is string && data.solutionId.size() > 0 && data.solutionId.size() < 100 &&
             data.authorId is string && data.authorId.size() > 0 && data.authorId.size() < 100 &&
             data.author is string && data.author.size() > 0 && data.author.size() < 100 &&
             data.text is string && data.text.size() > 0 && data.text.size() < 5000 &&
             data.date is string && data.date.size() < 50 &&
             data.createdAt is number;
    }

    function isValidSolutionVoteCreate(data) {
       return data.keys().hasAll(['userId', 'solutionId', 'type']) &&
              data.keys().size() == 3 &&
              data.userId is string && data.userId.size() > 0 && data.userId.size() < 100 &&
              data.solutionId is string && data.solutionId.size() > 0 && data.solutionId.size() < 100 &&
              data.type in ['up', 'down'];
    }

    function isValidSavedSolutionCreate(data) {
      return data.keys().hasAll(['userId', 'solutionId', 'savedAt']) &&
             data.keys().size() == 3 &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 100 &&
             data.solutionId is string && data.solutionId.size() > 0 && data.solutionId.size() < 100 &&
             data.savedAt is number;
    }

    function isValidReportCreate(data) {
      return data.keys().hasAll(['solutionId', 'reporterId', 'createdAt', 'status']) &&
             data.keys().size() == 4 &&
             data.solutionId is string && data.solutionId.size() > 0 && data.solutionId.size() < 100 &&
             data.reporterId is string && data.reporterId.size() > 0 && data.reporterId.size() < 100 &&
             data.createdAt is number &&
             data.status in ['pending', 'reviewed', 'resolved'];
    }


    match /users_public/{userId} {
      allow get: if isAuthenticated();
      allow list: if isAuthenticated();
      allow create: if isOwner(userId) && isValidId(userId) && isValidUserPublicCreate(incoming()) && incoming().uid == userId;
      allow update: if isOwner(userId) && isValidId(userId) && incoming().uid == existing().uid && incoming().diff(existing()).affectedKeys().hasOnly(['profilePic', 'avatarConfig', 'points', 'name', 'rank']);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidId(userId) && isValidUserCreate(incoming()) && incoming().uid == userId && (incoming().role == 'user' || isAdmin());
      allow update: if isOwner(userId) && isValidId(userId) && incoming().uid == existing().uid && (!('role' in incoming().diff(existing()).affectedKeys()) || incoming().role == existing().role || isAdmin());
      allow delete: if isAdmin();

      match /activity/{date} {
        allow get: if isOwner(userId) || isAdmin();
        allow list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidActivityCreate(incoming()) && incoming().userId == userId;
        allow update: if isOwner(userId) && incoming().userId == existing().userId && incoming().diff(existing()).affectedKeys().hasOnly(['questionsSolved', 'accuracy', 'timeSpent', 'pointsEarned']);
        allow delete: if isAdmin();
      }
    }

    match /solutions/{solutionId} {
      allow get: if isAuthenticated();
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && isValidId(solutionId) && isValidCommunitySolutionCreate(incoming()) && incoming().authorId == request.auth.uid;
      allow update: if isAuthenticated() && isValidId(solutionId) && incoming().authorId == existing().authorId && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['upvotes', 'downvotes', 'repliesCount', 'isVerified', 'text', 'tag', 'imageUrl'])) || isAdmin()
      );
      allow delete: if isAdmin() || (isAuthenticated() && existing().authorId == request.auth.uid);

      match /replies/{replyId} {
        allow get: if isAuthenticated();
        allow list: if isAuthenticated();
        allow create: if isAuthenticated() && isValidId(replyId) && isValidSolutionReplyCreate(incoming()) && incoming().authorId == request.auth.uid;
        allow update: if isAuthenticated() && isValidId(replyId) && incoming().authorId == existing().authorId && (
          (incoming().diff(existing()).affectedKeys().hasOnly(['text'])) || isAdmin()
        );
        allow delete: if isAdmin() || (isAuthenticated() && existing().authorId == request.auth.uid);
      }

      match /votes/{userId} {
        allow get: if isAuthenticated();
        allow list: if isAuthenticated();
        allow create: if isOwner(userId) && isValidSolutionVoteCreate(incoming()) && incoming().userId == userId;
        allow update: if isOwner(userId) && incoming().userId == existing().userId && incoming().diff(existing()).affectedKeys().hasOnly(['type']);
        allow delete: if isOwner(userId);
      }
    }

    match /savedSolutions/{savedSolutionId} {
      allow get: if isOwner(resource.data.userId);
      allow list: if isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isValidSavedSolutionCreate(incoming()) && incoming().userId == request.auth.uid;
      allow update: if false;
      allow delete: if isOwner(resource.data.userId);
    }

    match /reports/{reportId} {
      allow get: if isAdmin() || isOwner(resource.data.reporterId);
      allow list: if isAdmin();
      allow create: if isAuthenticated() && isValidReportCreate(incoming()) && incoming().reporterId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
